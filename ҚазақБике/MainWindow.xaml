    <Window x:Class="ҚазақБике.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ҚазақБике"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <!-- Стильдерді осында қосамыз -->
        <Window.Resources>
            <!-- Дөңгелек баттон стилі -->
            <Style x:Key="RoundButton" TargetType="Button">
                <Setter Property="Background" Value="#B78B5F"/>
                <!-- Құм түсті -->
                <Setter Property="Foreground" Value="#5A3A1E"/>
                <!-- Қою қоңыр -->
                <Setter Property="FontSize" Value="40"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="60"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                CornerRadius="15">
                                <!-- толық дөңгелек -->
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Window.Resources>

        
        <Grid>
        <Grid.RowDefinitions>
             <RowDefinition Height="130"/>
             <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
            
        <Grid.ColumnDefinitions>
             <ColumnDefinition Width="130"/>
             <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

            <!-- Жоғарғы фон баттон немесе панель -->
            <Button Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="#B78B5F"
                BorderThickness="0"
                Height="130"/>

               <Image Source="Imagesoiy/Ою мүйіз.jpeg"
                      Width="130" Height="130" 
                      Grid.Column="0"/>
               <TextBlock Text="Aina"
                          Grid.Column="1"
                          FontSize="24"
                          Foreground="#2F3E4D"
                          FontWeight="Bold"
                          Margin="5,0,0,0"/>
            

            <!-- Төменгі фон -->
            <Button Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Background="#4F6D7A"
                    BorderThickness="0"/>

            <Button Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,0,0"
                    Background="#FFF0D9"/>




        <!--<StackPanel Grid.Row="1" Grid.Column="0" Background="#FFF0D9" Margin="0,0,0,0" >
            <Button Height="30" Margin="0,5,0,0" Background="#4F6D7A" Content="Іс" Click="Section_Click"/>
            <Button Height="30" Margin="0,5,0,0" Background="#4F6D7A" Content="Өтініш" Click="Section_Click"/>
            <Button Height="30" Margin="0,5,0,0" Background="#4F6D7A" Content="Дәлел" Click="Section_Click"/>
            <Button Height="30" Margin="0,5,0,0" Background="#4F6D7A" Content="Талап Арыз" Click="Section_Click"/>
            <Button Height="30" Margin="0,5,0,0" Background="#4F6D7A" Content="Құжаттар" Click="Section_Click"/>
            <Button Height="30" Margin="0,5,0,0" Background="#4F6D7A" Content="Кезек" Click="Section_Click"/>
        </StackPanel>-->
        <Button Content="Архивті қарау" Click="ViewArchive_Click" Width="Auto" Height="Auto"  Margin="10"
                Grid.Row="1" Grid.Column="0" Background="#4F6D7A"/>



        <!-- Сол жақ стрелка TextBox үстіне шығару -->
        <Button Grid.Row="2" Grid.Column="0"
        Content="&#x2190;"
        Click="Left_Click"
        Width="40" Height="40"
        HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Margin="5,5,0,0"
        Style="{StaticResource RoundButton}"/>

        <!-- Оң жақ стрелка TextBox үстіне шығару -->
        <Button Grid.Row="2" Grid.Column="1"
        Content="&#x2192;"
        Width="40" Height="40"
        Click="Right_Click"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Margin="0,5,5,0"
        Style="{StaticResource RoundButton}"/>
            
        <TextBox 
                 Grid.Row="2" Grid.ColumnSpan="2"
                 Height="40" FontSize="16"
                 x:Name="Persontext" 
                 Margin="50,5,50,5" Background="White"/>

        <!-- Сақтау баттоны -->
        <Button x:Name="Dectiv"
                Grid.Row="3" Grid.Column="1"
                Content="Сақтау"
                FontSize="25"
                Width="110" Height="30"
                Margin="0,0,100,5"
                Style="{StaticResource RoundButton}"
                Click="Dectiv_Click"/>

        <TextBlock Grid.Row="0"
                   Grid.Column="1"
                   x:Name="Ainatext"
                   FontSize="20"
                   Margin="0,30,0,0"
                   Width="670"
                   Height="100"
                   Text=""
                   Padding="8,0,3,0"
                   Foreground="black"
                   FontWeight="SemiBold"
                   Background="#2F3E4D"
                   TextWrapping="Wrap"/>

        <WrapPanel x:Name="Stafftext"
                   Grid.Column="1"
                   Grid.Row="1"
                  
                 />
    </Grid>
    </Window> 